{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "NotebookEdit(*)",
      "Task(*)",
      "mcp__*",
      "mcp__playwright",
      "mcp__playwright__*",
      "mcp__plugin_github_github",
      "mcp__plugin_github_github__*",
      "mcp__plugin_context7_context7",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_vercel_vercel",
      "mcp__plugin_vercel_vercel__*",
      "Skill(*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(rm -fr:*)",
      "Bash(sudo:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "/Users/JuChan"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/JuChan/.claude/hooks/claude-remote-notification.sh"
          },
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code에서 확인이 필요합니다\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/JuChan/.claude/hooks/claude-remote-session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/JuChan/.claude/hooks/claude-remote-stop.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
